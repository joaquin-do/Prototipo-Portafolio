# Puerto asignado por Render (no cambiar en produccion)
PORT=4000

# Host de escucha (Render requiere 0.0.0.0)
HOST=0.0.0.0

# Entorno de ejecucion
NODE_ENV=production

# Panel admin en Vercel (sin barra final)
FRONTEND_URL=https://tu-admin.vercel.app

# App cliente en Vercel (sin barra final)
CLIENT_URL=https://tu-cliente.vercel.app

# Ruta opcional de SQLite (por defecto usa os.tmpdir() en produccion)
# DATABASE_PATH=/tmp/trust-recovery.sqlite
