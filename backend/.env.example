# Puerto asignado por Render (no cambiar en produccion)
PORT=4000

# Host de escucha (Render requiere 0.0.0.0)
HOST=0.0.0.0

# Entorno de ejecucion
NODE_ENV=production

# URL del frontend en Vercel (sin barra final)
# Puedes listar varios origenes separados por coma
FRONTEND_URL=https://tu-app.vercel.app

# Ruta opcional de SQLite (por defecto /tmp/trust-recovery.sqlite en produccion)
# DATABASE_PATH=/tmp/trust-recovery.sqlite
